# Скопіюйте цей файл у .env і впишіть ключ, щоб увімкнути СПРАВЖНЬОГО Claude.
# Без ключа AI-консьєрж працює як офлайн-симуляція (демо все одно повністю робоче).

ANTHROPIC_API_KEY=sk-ant-...

# Модель агента (необовʼязково). За замовчуванням claude-sonnet-5 (швидко/дешево).
# Для максимально переконливого демо можна поставити claude-opus-4-8.
MODEL=claude-sonnet-5

# Порт (необовʼязково)
PORT=3000

# Пароль до адмінки (/admin). За замовчуванням ryzlink-admin — ОБОВ'ЯЗКОВО змініть для показу.
ADMIN_PASSWORD=ryzlink-admin
